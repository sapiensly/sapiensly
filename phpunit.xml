<?xml version="1.0" encoding="UTF-8"?>
<phpunit xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:noNamespaceSchemaLocation="vendor/phpunit/phpunit/phpunit.xsd"
         bootstrap="vendor/autoload.php"
         colors="true"
>
    <testsuites>
        <testsuite name="Unit">
            <directory>tests/Unit</directory>
        </testsuite>
        <testsuite name="Feature">
            <directory>tests/Feature</directory>
        </testsuite>
    </testsuites>
    <source>
        <include>
            <directory>app</directory>
        </include>
    </source>
    <php>
        <ini name="memory_limit" value="512M"/>
        <env name="APP_ENV" value="testing"/>
        <env name="APP_MAINTENANCE_DRIVER" value="file"/>
        <env name="BCRYPT_ROUNDS" value="4"/>
        <env name="BROADCAST_CONNECTION" value="null"/>
        <env name="CACHE_STORE" value="array"/>
        <env name="DB_CONNECTION" value="pgsql"/>
        <env name="DB_HOST" value="127.0.0.1"/>
        <env name="DB_PORT" value="5432"/>
        <env name="DB_DATABASE" value="sapiensly_test"/>
        <env name="DB_USERNAME" value="postgres"/>
        <env name="DB_PASSWORD" value=""/>
        <!--
          Run the platform/tenant runtime connections as the owner in tests so
          the suite exercises app logic without RLS/role friction. Row-Level
          Security and structural isolation are covered by dedicated tests that
          connect as the real least-privilege roles.
        -->
        <env name="PLATFORM_DB_USERNAME" value="postgres"/>
        <env name="PLATFORM_DB_PASSWORD" value=""/>
        <env name="TENANT_DB_USERNAME" value="postgres"/>
        <env name="TENANT_DB_PASSWORD" value=""/>
        <env name="MAIL_MAILER" value="array"/>
        <!-- Document/app-file uploads default to S3; use local disk in tests so
             Storage::fake('local') covers them and no AWS credentials are needed. -->
        <env name="DOCUMENTS_DISK_DRIVER" value="local"/>
        <env name="QUEUE_CONNECTION" value="sync"/>
        <env name="SESSION_DRIVER" value="array"/>
        <env name="PULSE_ENABLED" value="false"/>
        <env name="TELESCOPE_ENABLED" value="false"/>
        <env name="NIGHTWATCH_ENABLED" value="false"/>
        <!--
            No live provider credentials, ever.

            The suite loads the developer's .env, so a real ANTHROPIC_API_KEY sitting
            there became part of the test environment — and tests that assert what
            happens WITHOUT a configured key ("sync needs a key", "a provider must be
            set up first") started failing on the machine of whoever had one. The
            suite passed or failed depending on the laptop, which is not a suite.

            Worse than flaky: a test that reaches a provider would do so with a real
            key and a real bill.

            A test that needs a key configures it itself (config(['ai.providers.…'])),
            which is explicit and scoped to that test.
        -->
        <env name="ANTHROPIC_API_KEY" value=""/>
        <env name="OPENAI_API_KEY" value=""/>
        <env name="AZURE_OPENAI_API_KEY" value=""/>
        <env name="GEMINI_API_KEY" value=""/>
        <env name="GROQ_API_KEY" value=""/>
        <env name="XAI_API_KEY" value=""/>
        <env name="DEEPSEEK_API_KEY" value=""/>
        <env name="MISTRAL_API_KEY" value=""/>
        <env name="OLLAMA_API_KEY" value=""/>
        <env name="OPENROUTER_API_KEY" value=""/>
        <env name="COHERE_API_KEY" value=""/>
        <env name="JINA_API_KEY" value=""/>
        <env name="VOYAGEAI_API_KEY" value=""/>
        <env name="ELEVENLABS_API_KEY" value=""/>
    </php>
</phpunit>

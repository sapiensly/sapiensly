APP_NAME=Laravel
APP_ENV=local
APP_KEY=
# Previous APP_KEYs (comma-separated) for graceful key rotation. Encrypted
# audit columns (integration_executions request/response) use APP_KEY; without
# the old key here a rotation makes existing rows undecryptable — and the cast
# is STRICT, so reads throw instead of degrading. Keep the prior key until all
# old rows have aged out.
# APP_PREVIOUS_KEYS=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Application runtime default = `platform` (least-privilege control plane).
# Migrations run as the owner role automatically (AppServiceProvider redirects
# migrate*/db:seed to the `pgsql` connection); passing --database=pgsql is
# optional. Tenant data lives in the `tenant` schema under RLS; control-plane
# data in the `platform` schema. The three roles map to three connections on the
# same host (and the same database — isolation is by schema, not by database).
DB_CONNECTION=platform
DB_HOST=127.0.0.1
DB_PORT=5432
# On Supabase the database is ALWAYS `postgres` (you can't create another one) —
# set DB_DATABASE=postgres there. The `sapiensly` name is only for a local DB you
# created yourself.
DB_DATABASE=sapiensly
# Owner role — owns both schemas, runs migrations/DDL, bypasses RLS.
DB_USERNAME=postgres
DB_PASSWORD=
# Control-plane runtime role (platform schema, no RLS — structural isolation).
PLATFORM_DB_USERNAME=platform_app
PLATFORM_DB_PASSWORD=
# IMPORTANT: behind PgBouncer, point PLATFORM_DB_HOST/PORT at a SESSION-pooling
# port (or a direct connection), NEVER a TRANSACTION-pooling port. Laravel relies
# on per-session state (search_path = "platform,public", multi-statement
# transactions, persistent connections); transaction pooling multiplexes server
# connections per-transaction and breaks that — the tell-tale symptom is
# "SQLSTATE[25P02]: current transaction is aborted" on the platform connection
# (e.g. when creating an app: the app_versions version-number query aborts).
# Also keep DB_PERSISTENT=false when going through a pooler.
# PLATFORM_DB_HOST=
# PLATFORM_DB_PORT=
# Tenant-data runtime role (tenant schema, subject to RLS). On Supabase point
# TENANT_DB_HOST/PORT at the SESSION pooler (5432) so `SET app.*` persists for
# the request; leave blank locally to reuse DB_HOST/DB_PORT.
TENANT_DB_USERNAME=tenant_app
TENANT_DB_PASSWORD=
# TENANT_DB_HOST=
# TENANT_DB_PORT=

# sslmode for the three Postgres connections. Supabase requires TLS; if the
# pooler rejects the connection ("server closed the connection unexpectedly"),
# set DB_SSLMODE=require. The platform/tenant connections also accept their own
# PLATFORM_DB_SSLMODE / TENANT_DB_SSLMODE (and PLATFORM_DB_DATABASE /
# TENANT_DB_DATABASE), falling back to DB_SSLMODE / DB_DATABASE. Use this for a
# mixed topology — e.g. tenant direct to the cluster over TLS (require) while
# platform goes through a LOCAL PgBouncer on loopback with no client TLS
# (PLATFORM_DB_SSLMODE=disable).
# DB_SSLMODE=prefer

# Persistent PDO on the runtime (platform/tenant) connections. PHP-FPM opens a
# fresh connection per request; against a managed DB the connect handshake costs
# ~100ms+, so reusing it per worker is a big win. Safe with the TRANSACTION
# pooler (it multiplexes); on the SESSION pooler each worker holds a backend, so
# size FPM workers against the pooler capacity. Does NOT reduce per-query
# latency — that's network RTT (co-locate the app and DB in one region).
# DB_PERSISTENT=true

# --- Supabase connection topology (production) ----------------------------
# The DIRECT connection (db.<ref>.supabase.co:5432) is IPv6-ONLY (IPv4 is a paid
# add-on) and caps at ~60 connections. Most app hosts (Forge on DO/AWS) have no
# routable IPv6, so the direct connection drops mid-handshake ("server closed
# the connection unexpectedly"), and even where it works it's slow for PHP-FPM
# (a fresh TLS+auth handshake per request + connection exhaustion).
#
# Route EVERYTHING — runtime AND migrations — through the Supavisor SESSION
# pooler, which is IPv4 and pooled. Session mode (not transaction) is required
# so RLS `SET app.*` and migration DDL hold across statements. Pooler usernames
# take the `<role>.<project-ref>` form. Copy the exact host from the dashboard
# (Connect -> Session pooler).
#
#   # Owner / migrations
#   DB_HOST=aws-0-<region>.pooler.supabase.com
#   DB_PORT=5432
#   DB_USERNAME=postgres.<project-ref>
#
#   # Runtime
#   PLATFORM_DB_HOST=aws-0-<region>.pooler.supabase.com
#   PLATFORM_DB_PORT=5432
#   PLATFORM_DB_USERNAME=platform_app.<project-ref>
#   TENANT_DB_HOST=aws-0-<region>.pooler.supabase.com
#   TENANT_DB_PORT=5432
#   TENANT_DB_USERNAME=tenant_app.<project-ref>
# Sapiensly requires PostgreSQL with the pgvector extension (RAG embeddings).
# Existing migrations create the pgvector extension; running them on sqlite will fail.

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=reverb
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis

# The runtime rate limiters (throttle:runtime-actions / builder-workflow-run /
# builder-ai) use this cache store. In production it MUST be a shared, atomic
# store so limits hold across PHP-FPM processes + Horizon workers — use `redis`.
# `database` also works as a shared store; `file`/`array` do NOT (per-process).
CACHE_STORE=database
# CACHE_PREFIX=

# Runtime rate limits (per minute unless noted). Tune per environment; see
# config/security.php. Daily AI cap is the cost ceiling for paid Claude turns.
# RL_RUNTIME_ACTIONS_USER=120
# RL_RUNTIME_ACTIONS_ORG=600
# RL_BUILDER_WF_USER=30
# RL_BUILDER_WF_ORG=120
# RL_BUILDER_AI_USER=20
# RL_BUILDER_AI_ORG=60
# RL_BUILDER_AI_ORG_DAILY=500
# RL_BUILDER_AI_USER_DAILY=200   # daily AI cap for accounts with no organization

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_SCHEME=tcp
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379
# REDIS_DB=0
# REDIS_CACHE_DB=1

# --- Managed Redis (Upstash) for production -------------------------------
# Upstash requires TLS and exposes ONLY logical DB 0. From the Upstash
# console copy the host/port/password (not the rediss:// URL — phpredis needs
# the discrete scheme) and set:
#   REDIS_SCHEME=tls
#   REDIS_HOST=<your-db>.upstash.io
#   REDIS_PORT=6379
#   REDIS_PASSWORD=<token>
#   REDIS_DB=0
#   REDIS_CACHE_DB=0        # Upstash has no DB 1; keys stay isolated by prefix
# Then put cache/queue/session on Redis:
#   CACHE_STORE=redis
#   QUEUE_CONNECTION=redis
#   SESSION_DRIVER=redis

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"


AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Reverb WebSocket
REVERB_APP_ID=
REVERB_APP_KEY=
REVERB_APP_SECRET=

# Local (Herd): Reverb serves TLS directly
# REVERB_HOST="myapp.test"
# REVERB_PORT=8080
# REVERB_SCHEME=https
# REVERB_TLS_CERT="/path/to/Certificates/myapp.test.crt"
# REVERB_TLS_KEY="/path/to/Certificates/myapp.test.key"

# Production (Forge): nginx proxies TLS, Reverb runs plain on 8080
# REVERB_HOST="myapp.com"
# REVERB_PORT=443
# REVERB_SCHEME=https
# (no REVERB_TLS_* needed — nginx handles TLS)

VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"

# LLM Providers
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Google social login (Sign in with Google). Create an OAuth client at
# https://console.cloud.google.com/apis/credentials and set the redirect URI to
# <APP_URL>/auth/google/callback. Leave blank to hide the Google button.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI="${APP_URL}/auth/google/callback"

# Absolute path to node for the workflow script.run QuickJS sandbox (PHP-FPM/queue
# workers may not have node on PATH). Leave as "node" if it is on PATH.
NODE_BINARY=node
